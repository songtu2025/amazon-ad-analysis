GERPGO_BASE_URL=https://open.gerpgo.com/api
GERPGO_APP_ID=your_app_id
GERPGO_APP_KEY=your_app_key
# 可选：如已手动获取 accessToken，可填写；留空时系统会用 AppID/AppKey 自动获取。
GERPGO_ACCESS_TOKEN=
GERPGO_MARKET_IDS=1
DATABASE_URL=sqlite:///./data/app.db
SYNC_COOLDOWN_SECONDS=120
# 可选本地定时同步，默认关闭，避免开发时频繁请求积加 API。
SYNC_SCHEDULER_ENABLED=false
SYNC_SCHEDULER_INTERVAL_MINUTES=360
SYNC_SCHEDULER_SOURCES=sp_keywords
